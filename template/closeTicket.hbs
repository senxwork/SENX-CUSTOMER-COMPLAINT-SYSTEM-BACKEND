<!doctype html>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!--[if !mso]><!-->
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!--<![endif]-->
    <!--[if mso]>
    <xml>
        <o:OfficeDocumentSettings>
            <o:AllowPNG/>
            <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
    </xml>
    <style>
        table { border-collapse: collapse; }
        td, th { font-family: Tahoma, sans-serif; }
    </style>
    <![endif]-->
    <style>
        body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
        body { margin: 0 !important; padding: 0 !important; width: 100% !important; }
    </style>
</head>

<body style="margin: 0; padding: 0; background-color: #eef2f7; font-family: 'Sarabun', Tahoma, sans-serif; -webkit-font-smoothing: antialiased; font-size: 14px; line-height: 1.6;">
    <!-- Wrapper -->
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #eef2f7;">
        <tr>
            <td align="center" style="padding: 30px 10px;">
                <!-- Container -->
                <!--[if mso]>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600">
                <tr><td>
                <![endif]-->
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 600px; border-collapse: collapse;">

                    <!-- Header -->
                    <tr>
                        <td align="center" style="background-color: #059669; padding: 32px 40px 24px 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td align="center" style="font-family: 'Sarabun', Tahoma, sans-serif; font-size: 11px; font-weight: 600; color: #a7f3d0; text-transform: uppercase; letter-spacing: 2px; padding-bottom: 6px;">
                                        TICKET COMPLETED
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="font-family: 'Sarabun', Tahoma, sans-serif; font-size: 22px; font-weight: 700; color: #ffffff; padding-bottom: 16px;">
                                        Customer Complaint Center
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <!--[if mso]>
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
                                        <td style="background-color: #047857; padding: 6px 20px; font-family: Tahoma, sans-serif; font-size: 14px; font-weight: 700; color: #ffffff; text-align: center;">
                                        {{dataBody.ticket_number}}
                                        </td></tr></table>
                                        <![endif]-->
                                        <!--[if !mso]><!-->
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                                            <tr>
                                                <td style="background-color: #047857; padding: 6px 24px; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; font-weight: 700; color: #ffffff; border-radius: 20px;">
                                                    {{dataBody.ticket_number}}
                                                </td>
                                            </tr>
                                        </table>
                                        <!--<![endif]-->
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Green accent line -->
                    <tr>
                        <td style="background-color: #10b981; height: 4px; font-size: 0; line-height: 0;">&nbsp;</td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="background-color: #ffffff; padding: 32px 40px;">

                            <!-- Greeting -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td style="font-family: 'Sarabun', Tahoma, sans-serif; font-size: 16px; color: #1e293b; padding-bottom: 6px; font-weight: 600;">
                                        สวัสดีครับ คุณ{{dataBody.contact_name}}
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #64748b; padding-bottom: 24px;">
                                        Ticket ที่มอบหมายให้หน่วยงานของคุณ ได้ดำเนินการ<strong style="color: #059669;">ปิดงานเรียบร้อยแล้ว</strong>
                                    </td>
                                </tr>
                            </table>

                            <!-- Ticket Info Table -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 24px;">
                                <!-- Section Header -->
                                <tr>
                                    <td colspan="2" style="background-color: #f1f5f9; padding: 10px 16px; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 12px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #059669;">
                                        &#9679; &nbsp;รายละเอียด Ticket
                                    </td>
                                </tr>
                                <!-- เลข Ticket -->
                                <tr>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 13px; color: #64748b; width: 140px; vertical-align: top;">
                                        เลข Ticket
                                    </td>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #1e3a5f; font-weight: 700;">
                                        {{dataBody.ticket_number}}
                                    </td>
                                </tr>
                                <!-- หมวดหมู่ -->
                                <tr>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 13px; color: #64748b; vertical-align: top;">
                                        หมวดหมู่
                                    </td>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #1e293b; font-weight: 600;">
                                        {{dataBody.category}}
                                    </td>
                                </tr>
                                <!-- หน่วยงาน -->
                                <tr>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 13px; color: #64748b; vertical-align: top;">
                                        หน่วยงาน
                                    </td>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #1e293b; font-weight: 600;">
                                        {{dataBody.department_name}}
                                    </td>
                                </tr>
                                <!-- วันครบกำหนด -->
                                <tr>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 13px; color: #64748b; vertical-align: top;">
                                        วันครบกำหนด
                                    </td>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #dc2626; font-weight: 700;">
                                        {{dataBody.due_date}}
                                    </td>
                                </tr>
                                <!-- สถานะ -->
                                <tr>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 13px; color: #64748b; vertical-align: top;">
                                        สถานะ
                                    </td>
                                    <td style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px;">
                                        <!--[if mso]>
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                                        <td style="background-color: #d1fae5; padding: 3px 14px; font-family: Tahoma, sans-serif; font-size: 12px; font-weight: 700; color: #059669;">
                                        &#10004; Completed
                                        </td></tr></table>
                                        <![endif]-->
                                        <!--[if !mso]><!-->
                                        <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                                        <td style="background-color: #d1fae5; padding: 3px 14px; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 12px; font-weight: 700; color: #059669; border-radius: 4px;">
                                        &#10004; Completed
                                        </td></tr></table>
                                        <!--<![endif]-->
                                    </td>
                                </tr>
                            </table>

                            <!-- Detail Section -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 28px;">
                                <tr>
                                    <td style="background-color: #f1f5f9; padding: 10px 16px; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 12px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #059669;">
                                        &#9679; &nbsp;รายละเอียดงาน
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px; background-color: #f8fafc; border-left: 3px solid #cbd5e1; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 14px; color: #334155; line-height: 1.7;">
                                        {{dataBody.ticket_detail}}
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td align="center" style="padding: 4px 0 16px 0;">
                                        <!--[if mso]>
                                        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{dataBody.public_url}}" style="height:48px;v-text-anchor:middle;width:340px;" arcsize="8%" strokecolor="#059669" fillcolor="#059669">
                                        <w:anchorlock/>
                                        <center style="color:#ffffff;font-family:Tahoma,sans-serif;font-size:15px;font-weight:700;">
                                        &#9654; &nbsp;ดูรายละเอียด Ticket
                                        </center>
                                        </v:roundrect>
                                        <![endif]-->
                                        <!--[if !mso]><!-->
                                        <a href="{{dataBody.public_url}}" target="_blank" style="display: inline-block; background-color: #059669; color: #ffffff; padding: 14px 40px; border-radius: 8px; text-decoration: none; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 15px; font-weight: 700; mso-hide: all;">&#9654; &nbsp;ดูรายละเอียด Ticket</a>
                                        <!--<![endif]-->
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="font-family: 'Sarabun', Tahoma, sans-serif; font-size: 12px; color: #94a3b8; padding-bottom: 8px;">
                                        คลิกปุ่มด้านบนเพื่อดูรายละเอียด Ticket
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="background-color: #f1f5f9; padding: 20px 40px; border-top: 1px solid #e2e8f0; font-family: 'Sarabun', Tahoma, sans-serif; font-size: 11px; color: #94a3b8;">
                            &copy; SEN X Management Co., Ltd. &mdash; All rights reserved
                        </td>
                    </tr>

                </table>
                <!--[if mso]>
                </td></tr></table>
                <![endif]-->
            </td>
        </tr>
    </table>
</body>

</html>
